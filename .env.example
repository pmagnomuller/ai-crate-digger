PORT=3000
MONGODB_URI=mongodb://localhost:27017/ai-crate-digger
DISCOGS_USER_TOKEN=replace_me
DISCOGS_SEED_TARGET=200
DISCOGS_SKIP_EMBEDDINGS=false
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=replace_me
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_RESPONSES_API_VERSION=v1
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_EMBEDDINGS_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_TTS_DEPLOYMENT=gpt-4o-mini-tts
# Optional: TTS on another Azure OpenAI resource/region (defaults to AZURE_OPENAI_* above).
# Must be an Azure OpenAI / Foundry OpenAI endpoint (…openai.azure.com or OpenAI tab on a cognitive account),
# not Azure AI Speech neural TTS (…tts.speech.microsoft.com) — different API.
# AZURE_OPENAI_TTS_ENDPOINT=https://your-tts-resource.openai.azure.com
# AZURE_OPENAI_TTS_API_KEY=replace_me
# If unset, the app defaults TTS to api-version 2025-01-01-preview (speech on Foundry often 404s with 2024-10-21).
# AZURE_OPENAI_TTS_API_VERSION=2025-01-01-preview
